# ================================================================
#  Factoryskills - Linux (さくらVPS) 用 環境設定テンプレート
# ================================================================
#
#  このファイルは Linux サーバ運用時のひな型です。
#
#  セットアップ手順（さくらVPS 例）:
#    1. このファイルを /opt/factoryskills/.env にコピー:
#         sudo cp deploy_linux/.env.linux.template /opt/factoryskills/.env
#    2. ★ マークの付いた項目を必ず変更（特に SECRET_KEY）
#    3. 所有者を factoryskills ユーザーに変更し、パーミッションを 600 に:
#         sudo chown factoryskills:factoryskills /opt/factoryskills/.env
#         sudo chmod 600 /opt/factoryskills/.env
#
# ================================================================

# ──────────────────────────────────────────────────────────────
#  ★ セキュリティ（必ず変更してください）
# ──────────────────────────────────────────────────────────────

# セッション署名用シークレットキー
# Linux で 48 バイトのランダム文字列を生成する例:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
# または:
#   openssl rand -base64 48
SECRET_KEY=<48バイトのランダム文字列を生成して設定>

# ──────────────────────────────────────────────────────────────
#  ★ サーバー公開設定
# ──────────────────────────────────────────────────────────────

# バインドアドレス
#   127.0.0.1  = ローカルからのみ（リバースプロキシ越し運用）
#   0.0.0.0    = 全ネットワークインタフェースで待ち受け（直接公開）
HOST=0.0.0.0

# ポート番号（さくらVPS のファイアウォール／パケットフィルタで開放が必要）
PORT=8000

# ──────────────────────────────────────────────────────────────
#  セッション設定
# ──────────────────────────────────────────────────────────────

# セッション有効期限（秒）デフォルト: 28800 = 8時間
SESSION_MAX_AGE=28800

# ──────────────────────────────────────────────────────────────
#  データベース・ファイルストレージ（Linux パス）
# ──────────────────────────────────────────────────────────────

# SQLite データベースファイル
DATABASE_PATH=/opt/factoryskills/data/app.db

# アップロードファイル保存先
UPLOAD_DIR=/opt/factoryskills/uploads

# 生成 PDF 出力先
OUTPUT_DIR=/opt/factoryskills/outputs

# ──────────────────────────────────────────────────────────────
#  日本語フォント設定
# ──────────────────────────────────────────────────────────────
#
# PDF スタンプ（PyMuPDF）に使用する日本語フォントの絶対パス。
# install_linux.sh で fonts-noto-cjk をインストール済みなら以下が標準。
# 別フォントを使う場合は変更してください。
FONT_PATH=/usr/share/fonts/opentype/noto/NotoSerifCJK-Regular.ttc

# ──────────────────────────────────────────────────────────────
#  運用設定
# ──────────────────────────────────────────────────────────────

# アップロードサイズ上限（MB）
MAX_UPLOAD_SIZE_MB=50

# 完了ジョブの自動クリーンアップ（時間）
# この時間を過ぎた完了/エラージョブのファイルが自動削除される
CLEANUP_AGE_HOURS=72

# ──────────────────────────────────────────────────────────────
#  Linux では未使用（明示的に空のままにしておく）
# ──────────────────────────────────────────────────────────────
#
# COM_TEMP_DIR は Windows COM 専用のため Linux では設定不要。
# .env で未指定なら web_app/core/config.py が /tmp/tmp_chukumon に
# フォールバックする（この値は Linux 経路では参照されない）。
#
# LIBREOFFICE_PATH は v2.1 以降は実コードから参照されない（廃止モジュール内のみ）。
# 念のため設定しないこと。
