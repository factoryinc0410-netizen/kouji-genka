# ================================================================
#  注文書自動作成システム — 環境変数テンプレート（開発者向け）
# ================================================================
#
#  使い方:
#    1. このファイルを `.env` にコピー:
#         cp .env.example .env
#    2. ★ マークの項目は必ず自環境に合わせて変更すること。
#    3. `.env` は .gitignore で除外されています。コミットしないこと。
#
#  Linux 本番（さくらVPS 等）では `deploy_linux/.env.linux.template`
#  を使ってください（systemd 経由のセットアップに最適化）。
# ================================================================

# ──────────────────────────────────────────────────────────────
#  ★ セキュリティ（必ず変更）
# ──────────────────────────────────────────────────────────────
# セッション署名用シークレット。十分に長いランダム文字列を設定する。
# 生成例:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=__CHANGE_ME__please_generate_a_random_string

# ──────────────────────────────────────────────────────────────
#  サーバー設定
# ──────────────────────────────────────────────────────────────
# 127.0.0.1 = ローカル限定 / 0.0.0.0 = 全 IF で公開
# 0.0.0.0 で起動するときは SECRET_KEY と admin パスワードを必ず変更してから。
HOST=127.0.0.1
PORT=8000

# セッション有効期限（秒）。デフォルト 8 時間。
SESSION_MAX_AGE=28800

# Cookie に Secure 属性を付ける（HTTPS 環境のみ true）。
# ローカル開発（HTTP）では false のまま。
# 受理値: true/false, 1/0, yes/no, on/off
SESSION_COOKIE_SECURE=false

# ──────────────────────────────────────────────────────────────
#  データベース・ファイルストレージ
# ──────────────────────────────────────────────────────────────
# 未指定なら web_app/core/config.py のデフォルト
# （web_app/data/app.db, web_app/uploads, web_app/outputs）が使われます。
# DATABASE_PATH=./web_app/data/app.db
# UPLOAD_DIR=./web_app/uploads
# OUTPUT_DIR=./web_app/outputs

# ──────────────────────────────────────────────────────────────
#  COM 一時ディレクトリ（Windows のみ使用）
# ──────────────────────────────────────────────────────────────
# Excel COM (xls→xlsx 変換) で使用。ASCII パス必須。
# Linux/macOS では参照されないので未指定で問題ありません。
# COM_TEMP_DIR=C:\tmp_chukumon

# ──────────────────────────────────────────────────────────────
#  日本語フォント（PDF スタンプ用）
# ──────────────────────────────────────────────────────────────
# Windows 例: C:\Windows\Fonts\msmincho.ttc
# Linux 例 : /usr/share/fonts/opentype/ipaexfont-mincho/ipaexm.ttf
#            /usr/share/fonts/opentype/noto/NotoSerifCJK-Regular.ttc
# 未指定の場合 Windows ではデフォルト、それ以外ではフォールバックリストから探索。
# FONT_PATH=

# ──────────────────────────────────────────────────────────────
#  運用
# ──────────────────────────────────────────────────────────────
# アップロードファイルサイズ上限（MB）
MAX_UPLOAD_SIZE_MB=50

# 完了/エラーになったジョブの自動クリーンアップ閾値（時間）
CLEANUP_AGE_HOURS=72

# クリーンアップ実行間隔（秒）。デフォルト 1 時間。
CLEANUP_INTERVAL=3600

# ユーザーごとに保持する最大ジョブ数（completed/error）。これを超える古い順から削除。
MAX_JOBS_PER_USER=4

# ジョブ処理タイムアウト（秒）。デフォルト 10 分。
JOB_TIMEOUT_SECONDS=600

# ──────────────────────────────────────────────────────────────
#  資格者証管理 (qualifications) — Gemini API による AI OCR
# ──────────────────────────────────────────────────────────────
# Google AI Studio で発行する API キー。
#   https://aistudio.google.com/apikey
# 未設定の場合、OCR は自動的に無効化され手動入力フローのみ動作する。
GEMINI_API_KEY=

# OCR を機能フラグでオフにする場合は false。デフォルト true。
# 受理値: true/false, 1/0, yes/no, on/off
QUALIFICATIONS_OCR_ENABLED=true

# 資格者証 1 枚の最大ファイルサイズ（MB）。デフォルト 50。
# 画像はクライアント側 Canvas で 1920px × JPEG 品質0.8 まで自動リサイズされるが、
# 元素材 (スマホ高解像度) を受けるため余裕を持たせている。
QUALIFICATIONS_MAX_FILE_MB=50

# 1 アップロードで投入可能なファイル枚数。デフォルト 5。
QUALIFICATIONS_MAX_FILES_PER_UPLOAD=5

# ──────────────────────────────────────────────────────────────
#  期限アラートメール通知 (qualifications)
# ──────────────────────────────────────────────────────────────
# scripts/send_expiration_alerts.py を cron から実行する際に参照される。
# SMTP_SERVER を空のままにするとメール送信は自動無効化される（cron は走るが
# 「smtp_not_configured」で skip）。
#
# Gmail の場合の設定例:
#   SMTP_SERVER=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=your_account@gmail.com
#   SMTP_PASSWORD=__app_password__   # アプリパスワード必須 (2段階認証)
#   SMTP_USE_TLS=true
#
# サーバ内のローカル MTA (postfix 等) を使う場合:
#   SMTP_SERVER=127.0.0.1
#   SMTP_PORT=25
#   SMTP_USE_TLS=false
#   (SMTP_USER / SMTP_PASSWORD は空でよい)
SMTP_SERVER=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# 受理値: true/false, 1/0, yes/no, on/off
SMTP_USE_TLS=true

# 送信元アドレス（ヘッダ "From"）。
ALERT_EMAIL_FROM=
# 宛先。複数指定はカンマ区切り。例: admin@example.com,safety@example.com
ALERT_EMAIL_TO=

# ──────────────────────────────────────────────────────────────
#  kouji-genka (KGK) アドオン連携
# ──────────────────────────────────────────────────────────────
# ポータルの「工事原価管理」カードがリンクする URL。
#
# - 本番: 既定値 "/kgk/" のまま。nginx が /kgk/ を 127.0.0.1:3000
#   (KGK Next.js) にプロキシする (skills/kouji-genka/infra/nginx/
#   kouji-genka-nginx.conf 参照)。
# - 開発: 同居 nginx を立てない場合、KGK の dev サーバへ直接遷移する
#   ため http://localhost:3000 を指定する。
#   ※ 開発時の KGK は basePath なしで動作するため、サブパス
#     "/kgk/" を経由するとリンクが壊れる。別 origin として扱うのが正。
#
# 詳細: skills/kouji-genka/docs/adr/ADR-001-addon-integration-strategy.md
# KGK_PORTAL_URL=http://localhost:3000
