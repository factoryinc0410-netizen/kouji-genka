# ================================================================
#  注文書自動作成システム — 環境変数テンプレート（開発者向け）
# ================================================================
#
#  使い方:
#    1. このファイルを `.env` にコピー:
#         cp .env.example .env
#    2. ★ マークの項目は必ず自環境に合わせて変更すること。
#    3. `.env` は .gitignore で除外されています。コミットしないこと。
#
#  Linux 本番（さくらVPS 等）では `deploy_linux/.env.linux.template`
#  を使ってください（systemd 経由のセットアップに最適化）。
# ================================================================

# ──────────────────────────────────────────────────────────────
#  ★ セキュリティ（必ず変更）
# ──────────────────────────────────────────────────────────────
# セッション署名用シークレット。十分に長いランダム文字列を設定する。
# 生成例:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=__CHANGE_ME__please_generate_a_random_string

# ──────────────────────────────────────────────────────────────
#  サーバー設定
# ──────────────────────────────────────────────────────────────
# 127.0.0.1 = ローカル限定 / 0.0.0.0 = 全 IF で公開
# 0.0.0.0 で起動するときは SECRET_KEY と admin パスワードを必ず変更してから。
HOST=127.0.0.1
PORT=8000

# セッション有効期限（秒）。デフォルト 8 時間。
SESSION_MAX_AGE=28800

# ──────────────────────────────────────────────────────────────
#  データベース・ファイルストレージ
# ──────────────────────────────────────────────────────────────
# 未指定なら web_app/core/config.py のデフォルト
# （web_app/data/app.db, web_app/uploads, web_app/outputs）が使われます。
# DATABASE_PATH=./web_app/data/app.db
# UPLOAD_DIR=./web_app/uploads
# OUTPUT_DIR=./web_app/outputs

# ──────────────────────────────────────────────────────────────
#  COM 一時ディレクトリ（Windows のみ使用）
# ──────────────────────────────────────────────────────────────
# Excel COM (xls→xlsx 変換) で使用。ASCII パス必須。
# Linux/macOS では参照されないので未指定で問題ありません。
# COM_TEMP_DIR=C:\tmp_chukumon

# ──────────────────────────────────────────────────────────────
#  日本語フォント（PDF スタンプ用）
# ──────────────────────────────────────────────────────────────
# Windows 例: C:\Windows\Fonts\msmincho.ttc
# Linux 例 : /usr/share/fonts/opentype/ipaexfont-mincho/ipaexm.ttf
#            /usr/share/fonts/opentype/noto/NotoSerifCJK-Regular.ttc
# 未指定の場合 Windows ではデフォルト、それ以外ではフォールバックリストから探索。
# FONT_PATH=

# ──────────────────────────────────────────────────────────────
#  運用
# ──────────────────────────────────────────────────────────────
# アップロードファイルサイズ上限（MB）
MAX_UPLOAD_SIZE_MB=50

# 完了/エラーになったジョブの自動クリーンアップ閾値（時間）
CLEANUP_AGE_HOURS=72
